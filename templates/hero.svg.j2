{% from "components/svg-header.j2" import terminal_header %}

<svg width="1200" height="420" viewBox="0 0 1200 420" fill="none" xmlns="http://www.w3.org/2000/svg" role="img"
  aria-labelledby="title description">
  <title id="title">{{ profile.identity.name }}</title>
  <desc id="description">
    {{ profile.identity.title }} — {{ profile.identity.tagline }}
  </desc>

  <defs>
    <linearGradient id="background" x1="0" y1="0" x2="1200" y2="420" gradientUnits="userSpaceOnUse">
      <stop stop-color="#0D1117" />
      <stop offset="1" stop-color="#161B22" />
    </linearGradient>

    <linearGradient id="accent" x1="120" y1="0" x2="1080" y2="0" gradientUnits="userSpaceOnUse">
      <stop stop-color="#58A6FF" />
      <stop offset="0.5" stop-color="#A371F7" />
      <stop offset="1" stop-color="#3FB950" />
    </linearGradient>

    <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="8" result="blur" />
      <feMerge>
        <feMergeNode in="blur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>

  <rect width="1200" height="420" rx="28" fill="url(#background)" />

  <rect x="1" y="1" width="1198" height="418" rx="27" stroke="#30363D" stroke-width="2" />

  <circle cx="54" cy="42" r="7" fill="#FF5F56" />

  <circle cx="80" cy="42" r="7" fill="#FFBD2E" />

  <circle cx="106" cy="42" r="7" fill="#27C93F" />

  {{ terminal_header(
  "system_identity",
  label_y=105
  ) }}

  <text x="70" y="215" fill="#F0F6FC" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="58" font-weight="700">
    {{ profile.identity.name }}
  </text>

  <text x="70" y="270" fill="url(#accent)" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="30"
    font-weight="600" filter="url(#glow)">
    {{ profile.identity.title }}
  </text>

  <text x="70" y="326" fill="#C9D1D9" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="26">
    {{ profile.identity.tagline }}
  </text>

  <text x="70" y="370" fill="#8B949E" font-family="ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
    font-size="20">
    {{ profile.identity.location }} • {{ profile.identity.languages | join(" / ") }}
  </text>

  <g opacity="0.28">
    <path d="M950 115H1070V235H950V115Z" stroke="#58A6FF" stroke-width="3" />

    <circle cx="1010" cy="175" r="34" stroke="#A371F7" stroke-width="3" />

    <path d="M1010 141V96M1010 254V209M976 175H931M1089 175H1044" stroke="#3FB950" stroke-width="3" />

    <path d="M980 145L1040 205M1040 145L980 205" stroke="#58A6FF" stroke-width="3" />
  </g>
</svg>