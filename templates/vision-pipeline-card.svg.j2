<svg width="1200" height="400" viewBox="0 0 1200 400" fill="none" xmlns="http://www.w3.org/2000/svg" role="img"
    aria-labelledby="title description">
    <title id="title">Real-time industrial AI vision pipeline</title>

    <desc id="description">
        Complete industrial computer vision pipeline from camera selection
        and dataset creation to TensorRT deployment on NVIDIA Jetson Orin.
    </desc>

    <defs>
        <linearGradient id="background" x1="0" y1="0" x2="1200" y2="400" gradientUnits="userSpaceOnUse">
            <stop stop-color="#0D1117" />
            <stop offset="1" stop-color="#161B22" />
        </linearGradient>

        <linearGradient id="accent" x1="70" y1="0" x2="1130" y2="0" gradientUnits="userSpaceOnUse">
            <stop stop-color="#58A6FF" />
            <stop offset="0.5" stop-color="#A371F7" />
            <stop offset="1" stop-color="#3FB950" />
        </linearGradient>

        <filter id="glow" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="5" result="blur" />

            <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
            </feMerge>
        </filter>
    </defs>

    <style>
        .card-border {
            fill: none;
            stroke: #30363d;
            stroke-width: 2;
            transition:
                stroke 0.25s ease,
                filter 0.25s ease;
        }

        .stage-box {
            fill: #161b22;
            stroke: #30363d;
            stroke-width: 2;
            transition:
                fill 0.25s ease,
                stroke 0.25s ease,
                filter 0.25s ease;
        }

        .stage:hover .stage-box {
            fill: #1f2937;
            stroke: #58a6ff;
            filter: url(#glow);
        }

        svg:hover .card-border {
            stroke: #58a6ff;
        }

        @media (prefers-reduced-motion: reduce) {

            .card-border,
            .stage-box {
                transition: none;
            }
        }
    </style>

    <rect width="1200" height="400" rx="28" fill="url(#background)" />

    <rect class="card-border" x="1" y="1" width="1198" height="398" rx="27" />

    <text x="70" y="58" fill="#8B949E" font-family="ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
        font-size="21">
        &gt; real_time_ai_vision_pipeline
    </text>

    <text x="70" y="112" fill="url(#accent)" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="34"
        font-weight="700">
        From industrial imaging to deployed AI inference
    </text>

    <text x="70" y="150" fill="#C9D1D9" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="18">
        Camera · lens · lighting · datasets · training · TensorRT · DeepStream · WebRTC
    </text>

    <g class="stage">
        <rect class="stage-box" x="70" y="195" width="150" height="118" rx="18" />
        <text x="145" y="235" fill="#58A6FF" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="17"
            font-weight="700" text-anchor="middle">
            Imaging
        </text>
        <text x="145" y="266" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            Camera · Lens
        </text>
        <text x="145" y="286" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            Lighting
        </text>
    </g>

    <g class="stage">
        <rect class="stage-box" x="245" y="195" width="150" height="118" rx="18" />
        <text x="320" y="235" fill="#58A6FF" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="17"
            font-weight="700" text-anchor="middle">
            Dataset
        </text>
        <text x="320" y="266" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            Label Studio
        </text>
        <text x="320" y="286" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            Pre-labeling
        </text>
    </g>

    <g class="stage">
        <rect class="stage-box" x="420" y="195" width="150" height="118" rx="18" />
        <text x="495" y="235" fill="#A371F7" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="17"
            font-weight="700" text-anchor="middle">
            Training
        </text>
        <text x="495" y="266" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            YOLOv26
        </text>
        <text x="495" y="286" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            YOLOv26 Pose
        </text>
    </g>

    <g class="stage">
        <rect class="stage-box" x="595" y="195" width="150" height="118" rx="18" />
        <text x="670" y="235" fill="#A371F7" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="17"
            font-weight="700" text-anchor="middle">
            Optimization
        </text>
        <text x="670" y="266" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            ONNX
        </text>
        <text x="670" y="286" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            TensorRT
        </text>
    </g>

    <g class="stage">
        <rect class="stage-box" x="770" y="195" width="150" height="118" rx="18" />
        <text x="845" y="235" fill="#3FB950" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="17"
            font-weight="700" text-anchor="middle">
            Deployment
        </text>
        <text x="845" y="266" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            Jetson Orin
        </text>
        <text x="845" y="286" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            DeepStream
        </text>
    </g>

    <g class="stage">
        <rect class="stage-box" x="945" y="195" width="185" height="118" rx="18" />
        <text x="1037" y="235" fill="#3FB950" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="17"
            font-weight="700" text-anchor="middle">
            Live robot vision
        </text>
        <text x="1037" y="266" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            GStreamer
        </text>
        <text x="1037" y="286" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="13"
            text-anchor="middle">
            WebRTC
        </text>
    </g>

    <text x="70" y="355" fill="#8B949E" font-family="Inter, Segoe UI, Arial, sans-serif" font-size="16">
        Reliable real-time operation requires the complete imaging and inference system,
        not only the neural network.
    </text>
</svg>